cat > .gitignore << 'EOF'
# Node modules
node_modules/
node_modules
*/node_modules/

# Environment files
.env
.env.local
.env.*.local

# Build outputs
dist/
build/
.DS_Store
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# IDE files
.vscode/
.idea/
*.swp
*.swo
*~

# OS files
Thumbs.db
.DS_Store

# Database files
*.sqlite
*.sqlite3

# Backend specific
backend/package-lock.json
backend/.env

# Frontend specific
frontend/package-lock.json
frontend/.env
frontend/dist/
EOF